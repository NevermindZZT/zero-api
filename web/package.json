{
  "name": "zero-api-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "postbuild": "node -e \"fs=require('fs'),p=require('path');t=p.resolve('../cmd/server/web/dist');fs.rmSync(t,{recursive:true,force:true});fs.cpSync('dist',t,{recursive:true})\""
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "pinia": "^3.0.2",
    "naive-ui": "^2.41.0",
    "@vicons/ionicons5": "^0.12.0",
    "axios": "^1.7.9",
    "echarts": "^5.6.0",
    "vue-echarts": "^7.0.3",
    "@vueuse/core": "^12.8.2"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "typescript": "~5.7.3",
    "vite": "^6.2.0",
    "vue-tsc": "^2.2.0",
    "copyfiles": "^2.4.1"
  }
}
